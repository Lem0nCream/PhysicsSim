@page "/"
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject Manager manager

<h1>Physics Simulation</h1>

<canvas id="simCanvas"
        width="1000"
        height="500"
        style="border:10px solid black;">
</canvas>
<hr>
<button @onclick="RestartSim">Restart</button>
<hr>
    <label for="scale">Meters per pixel: </label>
<input type="text" id="scale" placeholder="Meters per pixel" @bind="scale">
<p>1px = @scale m</p>
<hr>
<div class="input-group">
    <label for="magneticFieldStrength">Magnetic Field Strength (T) : </label>
    <input type="text" id="magneticFieldStrength" placeholder="Magnetic Field Strength (T)" @bind="magneticFieldStrength">
</div>
<hr>

<div class="input-group">
    <label for="isMagnetic">Is Magnetic? : </label>
    <input type="checkbox" @bind="isMagnetic">
</div>
<hr>

<div class="input-group">
    <label for="charge">Charge (C) : </label>
    <input type="text" id="charge" placeholder="Charge (C)" @bind="charge">
</div>
<hr>

<div class="input-group">
    <label for="resistance">Resistance (Ω) : </label>
    <input type="text" id="resistance" placeholder="Resistance (Ω)" @bind="resistance">
</div>
<hr>

<div class="input-group">
    <label for="conductivity">Conductivity (S/m) : </label>
    <input type="text" id="conductivity" placeholder="Conductivity (S/m)" @bind="conductivity">
</div>
<hr>

<div class="input-group">
    <label for="mass">Mass (kg) : </label>
    <input type="text" id="mass" placeholder="Mass (kg)" @bind="mass">
</div>
<hr>

<div class="input-group">
    <label for="isStatic">Is Static? : </label>
    <input type="checkbox" @bind="isStatic">
</div>
<hr>

<div class="input-group">
    <label for="isBattery">Is a Battery? : </label>
    <input type="checkbox" @bind="isBattery">
</div>
<hr>

<div class="input-group">
    <label for="voltage">Voltage (V) : </label>
    <input type="text" id="voltage" placeholder="Voltage (V)" @bind="voltage">
</div>
<hr>

<div class="input-group">
    <label for="xVelocity">X Velocity (px/tick) : </label>
    <input type="text" id="xVelocity" placeholder="X Velocity (px/tick)" @bind="xVelocity">
</div>
<hr>

<div class="input-group">
    <label for="yVelocity">Y Velocity (px/tick) : </label>
    <input type="text" id="yVelocity" placeholder="Y Velocity (px/tick)" @bind="yVelocity">
</div>
<hr>

<div class="input-group">
    <label for="length">Length (px) : </label>
    <input type="text" id="length" placeholder="Length (px)" @bind="length">
</div>
<hr>

<div class="input-group">
    <label for="height">Height (px) : </label>
    <input type="text" id="height" placeholder="Height (px)" @bind="height">
</div>
<hr>

<div class="input-group">
    <label for="color">Color (Hex Code) : </label>
    <input type="text" id="color" placeholder="Color (Hex Code)" @bind="color">
</div>
<hr>

<div class="input-group">
    <label for="friction">Friction (0-1) : </label>
    <input type="text" id="friction" placeholder="Friction (0-1)" @bind="friction">
</div>
<hr>

<div class="input-group">
    <label for="collideScale">Collision Scale (0-1) : </label>
    <input type="text" id="collideScale" placeholder="Collision Scale (0-1)" @bind="collideScale">
</div>
<hr>

<button @onclick="PresetBattery">Preset Battery</button>
<button @onclick="PresetResistor">Preset Resistor</button>
<button @onclick="PresetVerticalWire">Preset Vertical Wire</button>
<button @onclick="PresetHorizontalWire">Preset Horizontal Wire</button>
<button @onclick="PresetMagneticParticle">Preset Magnetic Particle</button>
<button @onclick="PresetChargeParticle">Preset Charged Particle</button>

@implements IAsyncDisposable
@code {
    private bool hasStarted = false;
    private readonly Random _random = new();
    private DotNetObjectReference<Home>? _dotNetRef;
    public string scale = "1";

    //object properties
    public float magneticFieldStrength = 0;
    public bool isMagnetic = false;
    public float charge = 0;
    public float resistance = 0;
    public float conductivity = 0;
    public float mass = 1;
    public bool isStatic = true;
    public bool isBattery = false;
    public float voltage = 0;
    public Vector2 center;
    public float xVelocity = 0;
    public float yVelocity = 0;
    public Vector2 velocity = new Vector2(0, 0);
    public float length = 8;
    public float height = 8;
    public string color = "#000000";
    public float friction = 0;
    public float collideScale = 1;
