    mass = 10;
    isStatic = true;
    isBattery = true;
    voltage = 9;
    xVelocity = 0;
    yVelocity = 0;
    length = 25;
    height = 25;
    color = "#F54D27";
    friction = 0;
    collideScale = 1;
}
