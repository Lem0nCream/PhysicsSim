protected override async Task OnAfterRenderAsync(bool firstRender)
{    
	if (firstRender && !hasStarted)
    {
        hasStarted = true;
        await StartSim();
    }
}
private CancellationTokenSource _cts;

protected override void OnInitialized()
{
    _cts = new CancellationTokenSource();
    _ = GameLoop(_cts.Token);
}
private async Task GameLoop(CancellationToken token)
{
    const float tickRate = 1f / 60f;
    float accumulator = 0f;

    const int renderRateMs = 50;
    int renderAccumulator = 0;

    var stopwatch = System.Diagnostics.Stopwatch.StartNew();
    long lastTime = stopwatch.ElapsedMilliseconds;

    while (!token.IsCancellationRequested)
    {
        long currentTime = stopwatch.ElapsedMilliseconds;
        float deltaTime = (currentTime - lastTime) / 1000f;
        lastTime = currentTime;

        accumulator += deltaTime;
        renderAccumulator += (int)(deltaTime * 1000);

        while (accumulator >= tickRate)
        {
            FixedUpdate(tickRate);
            accumulator -= tickRate;
        }

        if (renderAccumulator >= renderRateMs)
        {
            Render();
            SlowUpdate();
            renderAccumulator = 0;
        }

        await Task.Delay(16, token);
        manager.deltaTime = tickRate;
    }
}
    public async Task  FixedUpdate(float deltaTime)
    {
        foreach (var a in manager.objects)
        {
            if (!a.isStatic)
            {
                manager.CheckMagneticForces(a);
                manager.CheckElectricForces(a);
                manager.CheckLorentzForces(a);
            }
        }
        foreach (var a in manager.objects)
        {
            if (!a.isStatic)
            {
                a.ApplyVelocity(deltaTime);
            }
        }
        foreach (var a in manager.objects)
        {
            if (!a.isStatic)
            {
                manager.CheckCollision(a);
            }
        }
    }
    public async Task SlowUpdate()
    {
        List<PhysicsSimApp.Components.Object> conductiveTouchies = new List<PhysicsSimApp.Components.Object>();
        foreach (PhysicsSimApp.Components.Object o in manager.objects)
        {
            if (o.conductivity <= 0) continue;
            var cols = manager.GetCollisions(o);
            foreach (PhysicsSimApp.Components.Object a in cols)
            {
                if (a.conductivity > 0)
                conductiveTouchies.Add(a);
            }
        }
        manager.AddCircuit(conductiveTouchies);
    }
public async Task Render()
{
    var data = manager.objects.Select(o => new{ x = o.pos.X, y = o.pos.Y, l = o.length, h = o.height, c = o.color});
    await JS.InvokeVoidAsync("sim.renderFrame", data);
}
private async Task StartSim()
{
    scale = manager.distScale.ToString();
    try
    {
        if (JS is null)
        {
            return;
        }
        await JS.InvokeVoidAsync("sim.start");

        _dotNetRef ??= DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("sim.registerCanvasClickHandler", _dotNetRef);
    }
        catch (Exception ex)
    {
    }
}
private async Task RestartSim()
{
    for (int i = manager.objects.Count - 1; i >= 0; i--)
    {
        manager.objects.RemoveAt(i);
    }
}
[JSInvokable]
public Task SpawnOnClick(float x, float y)
{
    var obj = new PhysicsSimApp.Components.Object();
    obj.BuildObject(magneticFieldStrength, isMagnetic, charge, resistance, conductivity, mass, isStatic, isBattery, voltage, new Vector2(x-length/2,y-height/2), new Vector2(xVelocity, yVelocity), length, height, color, friction, collideScale);
    manager.objects.Add(obj);
    return Task.CompletedTask;

}

public async ValueTask DisposeAsync()
{
    if (_dotNetRef is not null)
    {
        await JS.InvokeVoidAsync("sim.unregisterCanvasClickHandler");
        _dotNetRef.Dispose();
        _dotNetRef = null;
    }

    _cts?.Cancel();
    _cts?.Dispose();
}
}